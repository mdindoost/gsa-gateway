# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# ── Roles & Permissions ───────────────────────────────────────────────────────
ADMIN_ROLE_NAME=GSA Officer

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./gsa_gateway.db

# ── Optional: Ollama local LLM ────────────────────────────────────────────────
# Set OLLAMA_ENABLED=true after running: ollama pull llama3
OLLAMA_ENABLED=true
OLLAMA_MODEL=llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT=90

# ── Bot behaviour ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Comma-separated Discord channel names where the bot will respond.
# Leave empty to allow all channels.
ALLOWED_CHANNELS=
BOT_PREFIX=gsa
