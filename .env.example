# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# ── Roles & Permissions ───────────────────────────────────────────────────────
ADMIN_ROLE_NAME=GSA Officer

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./gsa_gateway.db

# ── Optional: Ollama local LLM ────────────────────────────────────────────────
OLLAMA_ENABLED=false
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── Bot behaviour ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Comma-separated Discord channel names where the bot will respond.
# Leave empty to allow all channels.
ALLOWED_CHANNELS=
BOT_PREFIX=gsa
