# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# ── Roles & Permissions ───────────────────────────────────────────────────────
ADMIN_ROLE_NAME=GSA Officer

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./gsa_gateway.db

# ── Optional: Ollama local LLM ────────────────────────────────────────────────
# Set OLLAMA_ENABLED=true after running: ollama pull llama3.1:8b
OLLAMA_ENABLED=true
OLLAMA_MODEL=llama3.1:8b
OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT=60
CHROMA_DB_PATH=./chroma_db
CONVERSATION_TIMEOUT_MINUTES=60
CONVERSATION_MAX_TURNS=5
ASK_GSA_CHANNEL=ask-gsa
MATHCAFE_CHANNEL=gsa-mathcafe
MATHCAFE_ENABLED=true
EMBEDDING_MODEL=nomic-embed-text

# ── Bot behaviour ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Comma-separated Discord channel names where the bot will respond.
# Leave empty to allow all channels.
ALLOWED_CHANNELS=
BOT_PREFIX=gsa

# ── Announcement channels (must match Discord channel names exactly) ──────────
CHANNEL_ANNOUNCEMENTS=gsa-announcements
CHANNEL_EVENTS=gsa-events
CHANNEL_FOOD=gsa-food
CHANNEL_FUNDING=gsa-funding
CHANNEL_WELLNESS=gsa-wellness
CHANNEL_RESEARCH=gsa-research
CHANNEL_INTERNATIONAL=gsa-international

# ── Scheduler settings ────────────────────────────────────────────────────────
# Daily digest post time (UTC, 24h)
DAILY_DIGEST_HOUR=9
DAILY_DIGEST_MINUTE=0
# How often to check for upcoming reminders (minutes)
REMINDER_CHECK_INTERVAL=30

# ── Football / FIFA World Cup 2026 ────────────────────────────────────────────
FOOTBALL_API_KEY=
FOOTBALL_ENABLED=false
FOOTBALL_CHANNEL=world-cup-2026
FOOTBALL_POLL_INTERVAL=60
FOOTBALL_ORG_SLUG=gsa
# Per-goal scorer/minute feed (X-Unfold-Goals) is a PAID football-data.org
# feature. Leave false on the free tier (saves a wasted API call per goal);
# set true only with a paid key to get scorer + minute in goal posts.
FOOTBALL_UNFOLD_GOALS=false
# Daily World Cup fixtures digest (needs V2_SCHEDULER_ENABLED + FOOTBALL_API_KEY).
# Posts each match day's schedule (with FIFA venues) at WC_FIXTURES_HOUR_ET, ET.
WC_FIXTURES_ENABLED=false
WC_FIXTURES_HOUR_ET=9

# ── v2 publishing wire (flip to true to enable; false = v1 behavior) ──
V2_RETRIEVER_ENABLED=false
V2_SCHEDULER_ENABLED=false
V2_WORLDCUP_ENABLED=false
